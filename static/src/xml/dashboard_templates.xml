<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="custom_dashboard.Dashboard">
        <div class="cd-dashboard bg-gray-50 px-5 py-4 w-full">

            <!-- Header -->
            <div class="mb-5 flex items-center justify-between">
                <div>
                    <h1 class="text-xl font-bold text-gray-800">Dashboard Ejecutivo</h1>
                    <p class="text-xs text-gray-500 mt-0.5">Resumen de facturación, ventas y productos</p>
                </div>
                <div class="flex items-center gap-2 bg-white rounded-xl shadow-sm border border-gray-200 px-4 py-2">
                    <i class="fa-solid fa-calendar-days text-gray-400 text-xs"></i>
                    <span class="text-xs text-gray-500 font-medium">Período:</span>
                    <input type="date" t-ref="dateFrom" class="text-xs border-0 focus:ring-0 text-gray-700 cursor-pointer" t-on-change="onDateChange"/>
                    <i class="fa-solid fa-arrow-right text-gray-300 text-xs"></i>
                    <input type="date" t-ref="dateTo" class="text-xs border-0 focus:ring-0 text-gray-700 cursor-pointer" t-on-change="onDateChange"/>
                    <button t-on-click="resetFilters" class="ml-1 text-xs bg-gray-100 hover:bg-gray-200 text-gray-600 px-2 py-1 rounded-lg transition-colors flex items-center gap-1">
                        <i class="fa-solid fa-rotate-left text-xs"></i>
                        Hoy
                    </button>
                </div>
            </div>

            <!-- Loading -->
            <t t-if="state.loading">
                <div class="flex items-center justify-center h-64">
                    <div class="text-center">
                        <div class="cd-spinner mx-auto mb-4"></div>
                        <p class="text-gray-400 text-sm">Cargando datos...</p>
                    </div>
                </div>
            </t>

            <t t-if="!state.loading">

                <!-- ===== FACTURACIÓN ===== -->
                <div class="mb-5">
                    <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3 flex items-center gap-2">
                        <i class="fa-solid fa-circle text-indigo-500 text-xs"></i>
                        Facturación
                    </h2>
                    <div class="grid gap-3" style="grid-template-columns: repeat(5, 1fr);">

                        <div class="cd-card cd-card-indigo bg-white rounded-xl border border-gray-100 p-4 cursor-pointer hover:border-indigo-200 group" t-on-click="() => this.goToInvoices('posted')">
                            <div class="flex items-start justify-between mb-2">
                                <div class="p-2 bg-indigo-50 rounded-lg group-hover:bg-indigo-100 transition-colors">
                                    <i class="fa-solid fa-file-invoice text-indigo-600 text-sm w-4 text-center"></i>
                                </div>
                                <span class="text-xs text-green-500 font-medium bg-green-50 px-1.5 py-0.5 rounded-full">Emitido</span>
                            </div>
                            <div class="cd-value text-xl font-bold text-gray-800 mb-0.5"><t t-esc="formatCurrency(state.data.billing.total_invoiced)"/></div>
                            <div class="text-xs text-gray-400">Total Facturado</div>
                            <div class="text-xs text-gray-500 mt-0.5"><t t-esc="state.data.billing.count_invoices"/> facturas</div>
                        </div>

                        <div class="cd-card cd-card-green bg-white rounded-xl border border-gray-100 p-4 cursor-pointer hover:border-green-200 group" t-on-click="() => this.goToInvoices('paid')">
                            <div class="flex items-start justify-between mb-2">
                                <div class="p-2 bg-green-50 rounded-lg group-hover:bg-green-100 transition-colors">
                                    <i class="fa-solid fa-circle-check text-green-600 text-sm w-4 text-center"></i>
                                </div>
                                <span class="text-xs text-green-600 font-medium bg-green-50 px-1.5 py-0.5 rounded-full">Pagado</span>
                            </div>
                            <div class="cd-value text-xl font-bold text-gray-800 mb-0.5"><t t-esc="formatCurrency(state.data.billing.total_paid)"/></div>
                            <div class="text-xs text-gray-400">Total Cobrado</div>
                        </div>

                        <div class="cd-card cd-card-yellow bg-white rounded-xl border border-gray-100 p-4 cursor-pointer hover:border-yellow-200 group" t-on-click="() => this.goToInvoices('not_paid')">
                            <div class="flex items-start justify-between mb-2">
                                <div class="p-2 bg-yellow-50 rounded-lg group-hover:bg-yellow-100 transition-colors">
                                    <i class="fa-solid fa-hourglass-half text-yellow-600 text-sm w-4 text-center"></i>
                                </div>
                                <span class="text-xs text-yellow-600 font-medium bg-yellow-50 px-1.5 py-0.5 rounded-full">Pendiente</span>
                            </div>
                            <div class="cd-value text-xl font-bold text-gray-800 mb-0.5"><t t-esc="formatCurrency(state.data.billing.total_pending)"/></div>
                            <div class="text-xs text-gray-400">Por Cobrar</div>
                        </div>

                        <div class="cd-card cd-card-red bg-white rounded-xl border border-gray-100 p-4 cursor-pointer hover:border-red-200 group" t-on-click="goToOverdueInvoices">
                            <div class="flex items-start justify-between mb-2">
                                <div class="p-2 bg-red-50 rounded-lg group-hover:bg-red-100 transition-colors">
                                    <i class="fa-solid fa-circle-xmark text-red-600 text-sm w-4 text-center"></i>
                                </div>
                                <span class="text-xs text-red-600 font-medium bg-red-50 px-1.5 py-0.5 rounded-full"><t t-esc="state.data.billing.count_overdue"/> fact.</span>
                            </div>
                            <div class="cd-value text-xl font-bold text-red-600 mb-0.5"><t t-esc="formatCurrency(state.data.billing.total_overdue)"/></div>
                            <div class="text-xs text-gray-400">Vencidas</div>
                        </div>

                        <div class="cd-card cd-card-orange bg-white rounded-xl border border-gray-100 p-4 cursor-pointer hover:border-orange-200 group" t-on-click="goToUpcomingInvoices">
                            <div class="flex items-start justify-between mb-2">
                                <div class="p-2 bg-orange-50 rounded-lg group-hover:bg-orange-100 transition-colors">
                                    <i class="fa-solid fa-triangle-exclamation text-orange-500 text-sm w-4 text-center"></i>
                                </div>
                                <span class="text-xs text-orange-600 font-medium bg-orange-50 px-1.5 py-0.5 rounded-full">30 días</span>
                            </div>
                            <div class="cd-value text-xl font-bold text-orange-600 mb-0.5"><t t-esc="formatCurrency(state.data.billing.total_upcoming)"/></div>
                            <div class="text-xs text-gray-400">Por Vencer</div>
                        </div>

                    </div>
                </div>

                <!-- ===== VENTAS ===== -->
                <div class="mb-5">
                    <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3 flex items-center gap-2">
                        <i class="fa-solid fa-circle text-blue-500 text-xs"></i>
                        Ventas
                    </h2>
                    <div class="grid gap-3" style="grid-template-columns: repeat(4, 1fr);">

                        <div class="cd-card cd-card-blue bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl p-4 cursor-pointer hover:shadow-lg transition-all text-white" t-on-click="() => this.goToSales('sale')">
                            <div class="flex items-start justify-between mb-2">
                                <div class="p-2 bg-white/20 rounded-lg">
                                    <i class="fa-solid fa-coins text-white text-sm w-4 text-center"></i>
                                </div>
                            </div>
                            <div class="cd-value text-xl font-bold mb-0.5"><t t-esc="formatCurrency(state.data.sales.total_sales)"/></div>
                            <div class="text-xs text-blue-100">Total en Ventas</div>
                        </div>

                        <div class="cd-card cd-card-blue bg-white rounded-xl border border-gray-100 p-4 cursor-pointer hover:border-blue-200 group" t-on-click="() => this.goToSales('sale')">
                            <div class="flex items-start justify-between mb-2">
                                <div class="p-2 bg-blue-50 rounded-lg group-hover:bg-blue-100 transition-colors">
                                    <i class="fa-solid fa-box text-blue-600 text-sm w-4 text-center"></i>
                                </div>
                            </div>
                            <div class="cd-value text-xl font-bold text-gray-800 mb-0.5"><t t-esc="state.data.sales.count_orders"/></div>
                            <div class="text-xs text-gray-400">Órdenes Confirmadas</div>
                        </div>

                        <div class="cd-card cd-card-purple bg-white rounded-xl border border-gray-100 p-4 cursor-pointer hover:border-purple-200 group" t-on-click="goToCustomers">
                            <div class="flex items-start justify-between mb-2">
                                <div class="p-2 bg-purple-50 rounded-lg group-hover:bg-purple-100 transition-colors">
                                    <i class="fa-solid fa-users text-purple-600 text-sm w-4 text-center"></i>
                                </div>
                            </div>
                            <div class="cd-value text-xl font-bold text-gray-800 mb-0.5"><t t-esc="state.data.sales.count_customers"/></div>
                            <div class="text-xs text-gray-400">Clientes Únicos</div>
                        </div>

                        <div class="flex flex-col gap-3">
                            <div class="cd-card cd-card-teal bg-white rounded-xl border border-gray-100 p-3 cursor-pointer hover:border-teal-200 group flex-1" t-on-click="() => this.goToSales('sale')">
                                <div class="flex items-center justify-between">
                                    <div>
                                        <div class="cd-value text-base font-bold text-gray-800"><t t-esc="formatCurrency(state.data.sales.avg_ticket)"/></div>
                                        <div class="text-xs text-gray-400">Ticket Promedio</div>
                                    </div>
                                    <div class="p-2 bg-teal-50 rounded-lg group-hover:bg-teal-100 transition-colors">
                                        <i class="fa-solid fa-chart-line text-teal-600 text-sm w-4 text-center"></i>
                                    </div>
                                </div>
                            </div>
                            <div class="cd-card cd-card-amber bg-white rounded-xl border border-gray-100 p-3 cursor-pointer hover:border-amber-200 group flex-1" t-on-click="() => this.goToSales('draft')">
                                <div class="flex items-center justify-between">
                                    <div>
                                        <div class="cd-value text-base font-bold text-gray-800"><t t-esc="state.data.sales.count_quotations"/></div>
                                        <div class="text-xs text-gray-400">Cotizaciones Abiertas</div>
                                    </div>
                                    <div class="p-2 bg-amber-50 rounded-lg group-hover:bg-amber-100 transition-colors">
                                        <i class="fa-solid fa-file-pen text-amber-600 text-sm w-4 text-center"></i>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- ===== GRÁFICOS ===== -->
                <div class="grid gap-4 mb-5" style="grid-template-columns: 1fr 1fr 1fr;">
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
                        <h3 class="text-xs font-semibold text-gray-600 mb-3 flex items-center gap-2">
                            <i class="fa-solid fa-chart-bar text-blue-400"></i>
                            Ventas por Período
                        </h3>
                        <div class="relative" style="height: 220px;">
                            <canvas t-ref="salesChart"></canvas>
                        </div>
                    </div>
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
                        <h3 class="text-xs font-semibold text-gray-600 mb-3 flex items-center gap-2">
                            <i class="fa-solid fa-chart-area text-indigo-400"></i>
                            Facturación por Mes
                        </h3>
                        <div class="relative" style="height: 220px;">
                            <canvas t-ref="billingChart"></canvas>
                        </div>
                    </div>
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
                        <h3 class="text-xs font-semibold text-gray-600 mb-3 flex items-center gap-2">
                            <i class="fa-solid fa-chart-pie text-purple-400"></i>
                            Facturación por Cliente
                        </h3>
                        <t t-if="!state.data.billing_by_customer or !state.data.billing_by_customer.values or state.data.billing_by_customer.values.length === 0">
                            <div class="flex items-center justify-center h-48 text-gray-300 text-xs">
                                <div class="text-center">
                                    <i class="fa-solid fa-chart-pie text-4xl mb-2 block"></i>
                                    Sin datos
                                </div>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="relative" style="height: 220px;">
                                <canvas t-ref="customerPie"></canvas>
                            </div>
                            <p class="text-xs text-gray-400 text-center mt-2">
                                <i class="fa-solid fa-arrow-pointer mr-1"></i>Click en un sector para ver las facturas
                            </p>
                        </t>
                    </div>
                </div>

                <!-- ===== TOP PRODUCTOS ===== -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-4">
                    <h3 class="text-xs font-semibold text-gray-600 mb-3 flex items-center gap-2">
                        <i class="fa-solid fa-ranking-star text-amber-400"></i>
                        Productos Más Vendidos
                    </h3>
                    <t t-if="state.data.top_products.length === 0">
                        <div class="text-center py-8 text-gray-400 text-sm">
                            <i class="fa-solid fa-box-open text-3xl mb-2 block text-gray-300"></i>
                            No hay datos de ventas para el período seleccionado.
                        </div>
                    </t>
                    <t t-else="">
                        <table class="w-full text-sm" style="table-layout: fixed;">
                            <colgroup>
                                <col style="width: 40px;"/>
                                <col/>
                                <col style="width: 110px;"/>
                                <col style="width: 140px;"/>
                                <col style="width: 260px;"/>
                            </colgroup>
                            <thead>
                                <tr class="text-left text-xs text-gray-400 uppercase tracking-wider border-b border-gray-100">
                                    <th class="pb-2 font-medium">#</th>
                                    <th class="pb-2 font-medium">Producto</th>
                                    <th class="pb-2 font-medium text-right">Cantidad</th>
                                    <th class="pb-2 font-medium text-right">Ingresos</th>
                                    <th class="pb-2 font-medium pl-4">Participación</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="state.data.top_products" t-as="product" t-key="product.id">
                                    <tr class="border-b border-gray-50 hover:bg-gray-50 cursor-pointer transition-colors" t-on-click="() => this.goToProduct(product.id)">
                                        <td class="py-2">
                                            <span t-attf-class="inline-flex items-center justify-center w-6 h-6 rounded-full text-xs font-bold #{product_index === 0 ? 'bg-yellow-100 text-yellow-700' : product_index === 1 ? 'bg-gray-100 text-gray-500' : product_index === 2 ? 'bg-orange-100 text-orange-600' : 'bg-gray-50 text-gray-400'}">
                                                <t t-esc="product_index + 1"/>
                                            </span>
                                        </td>
                                        <td class="py-2 pr-4">
                                            <span class="font-medium text-gray-700 hover:text-blue-600 transition-colors text-sm truncate block"><t t-esc="product.name"/></span>
                                        </td>
                                        <td class="py-2 text-right text-gray-600 text-sm"><t t-esc="product.qty"/></td>
                                        <td class="py-2 text-right font-semibold text-gray-800 text-sm"><t t-esc="formatCurrency(product.revenue)"/></td>
                                        <td class="py-2 pl-4">
                                            <div style="display: flex; align-items: center; gap: 10px;">
                                                <div style="flex: 1; background: #f3f4f6; border-radius: 9999px; height: 8px;">
                                                    <div style="background: #3b82f6; border-radius: 9999px; height: 8px; transition: width 0.3s ease;" t-att-style="'width: ' + getProductShare(product.revenue) + '%'"></div>
                                                </div>
                                                <span style="font-size: 11px; color: #6b7280; font-weight: 500; white-space: nowrap; min-width: 30px; text-align: right;"><t t-esc="getProductShare(product.revenue)"/>%</span>
                                            </div>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                </div>

            </t>
        </div>
    </t>

</templates>
